# ===========================
# Batman AI - Environment Variables
# ===========================

# App
APP_NAME=Batman AI
DEBUG=false

# JWT (CHANGE THIS IN PRODUCTION!)
JWT_SECRET_KEY=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# MongoDB (Atlas URI for production)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=batman_ai

# Redis (Upstash URL for production)
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=86400

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Groq (Cloud LLM Fallback - Optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# PDF Processing
MAX_PDF_SIZE_MB=20
MAX_PDF_PAGES=100
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Rate Limiting
RATE_LIMIT_QPM=10

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
